<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="?android:attr/windowBackground">

    <TextView
        android:id="@+id/tvIntercomTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/intercom_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#00BCD4"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/swSpyMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/intercom_spy_mode"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/swMuteBruce"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/intercom_mute_bruce"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnPTT"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="@string/intercom_ptt_hold"
        android:background="@drawable/circle_button"
        style="@style/Widget.Material3.Button.TonalButton"
        android:textSize="18sp"
        android:elevation="8dp"/>

    <TextView
        android:id="@+id/tvIntercomStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/intercom_ready"
        android:alpha="0.7"/>

</LinearLayout>
