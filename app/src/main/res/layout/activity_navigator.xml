<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Live Screen View (z WebUI) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_margin="16dp"
        android:backgroundTint="#000000">
        <WebView
            android:id="@+id/wvScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000" />
    </androidx.cardview.widget.CardView>

    <!-- DPAD Layout -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        android:padding="20dp"
        android:layout_gravity="center">

        <ImageButton
            android:id="@+id/btnNavPageUp"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_media_ff"
            android:contentDescription="Next Page" />

        <ImageButton
            android:id="@+id/btnNavUp"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/arrow_up_float"
            android:contentDescription="Up" />

        <ImageButton
            android:id="@+id/btnNavMenu"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_more"
            android:contentDescription="Menu" />

        <ImageButton
            android:id="@+id/btnNavPrev"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_media_play"
            android:rotation="180"
            android:contentDescription="Left" />

        <Button
            android:id="@+id/btnNavSel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:text="OK"
            android:backgroundTint="#02de02"
            android:textColor="#000000" />

        <ImageButton
            android:id="@+id/btnNavNext"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="Right" />

        <ImageButton
            android:id="@+id/btnNavPageDown"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_media_rew"
            android:contentDescription="Prev Page" />

        <ImageButton
            android:id="@+id/btnNavDown"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/arrow_down_float"
            android:contentDescription="Down" />

        <ImageButton
            android:id="@+id/btnNavEsc"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back" />
    </GridLayout>

    <Button
        android:id="@+id/btnReloadScreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RELOAD SCREEN"
        android:layout_gravity="center"
        style="@style/Widget.Material3.Button.TextButton" />

</LinearLayout>