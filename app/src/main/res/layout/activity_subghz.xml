<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0A0A0A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sub-GHz Smart Clone"
        android:textColor="#2196F3"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- Status Skanowania -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.Material3.CardView.Filled">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tvScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: IDLE"
                android:textStyle="bold"/>
            <ProgressBar
                android:id="@+id/pbScanning"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>
            <Button
                android:id="@+id/btnStartAutoScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="START AUTO-DETECTION"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Wynik analizy -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last Detected Signal:"
        android:textSize="12sp"
        android:alpha="0.7"
        android:layout_marginBottom="8dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        style="@style/Widget.Material3.CardView.Elevated">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tvSignalDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wait for signal..."
                android:fontFamily="monospace"
                android:textSize="14sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginVertical="16dp"/>

            <Button
                android:id="@+id/btnCloneSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CLONE TO MY REMOTES"
                android:enabled="false"
                style="@style/Widget.Material3.Button.TonalButton"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnSubGhzBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CLOSE"
        style="@style/Widget.Material3.Button.TextButton"/>

</LinearLayout>
