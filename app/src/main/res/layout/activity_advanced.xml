<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advanced_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF5722"
            android:layout_marginBottom="24dp"/>

        <!-- Network Utilities -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Network Utilities"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>
                <Button
                    android:id="@+id/btnOpenScanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/net_scanner_scan"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja WPS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_wifi_wps"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etWpsPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="8-digit PIN"
                    android:inputType="number"
                    android:autofillHints="none"
                    android:layout_marginTop="8dp"/>
                <Button
                    android:id="@+id/btnConnectWps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GET PASSWORD"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja C2 Bridge -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_c2_bridge"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_c2_host"
                    android:layout_marginTop="12dp"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/etC2Host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:autofillHints="none"
                    android:hint="attacker.com or 1.2.3.4"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_c2_port"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/etC2Port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="4444"
                    android:autofillHints="none"
                    android:inputType="number"/>
                <Button
                    android:id="@+id/btnStartBridge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_start_bridge"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swSocksProxy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_socks_tunnel"
                    android:layout_marginTop="8dp"
                    android:checked="true"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swPersistence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_persistence"
                    android:layout_marginTop="4dp"
                    android:checked="true"/>

                <TextView
                    android:id="@+id/tvBridgeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_c2_status"
                    android:layout_marginTop="12dp"
                    android:textSize="12sp"
                    android:textColor="#999999"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja Trojan Agent Control -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trojan Agent Dashboard"
                    android:textStyle="bold"
                    android:textColor="#E91E63"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    <View
                        android:id="@+id/vAgentStatus"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@android:color/darker_gray"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tvAgentStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/agent_status_offline"
                        android:textSize="12sp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnAgentTrigger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="REMOTE TRIGGER IR (Panic)"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <Button
                    android:id="@+id/btnAgentFetchLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EXFILTRATE CAPTURED DATA"
                    style="@style/Widget.Material3.Button.TextButton"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja nRF24 RF Tools -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_nrf_tools"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>

                <Button
                    android:id="@+id/btnNrfScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_nrf_scan"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvNrfResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_nrf_discovered"
                    android:layout_marginTop="8dp"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>

                <EditText
                    android:id="@+id/etNrfPayload"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/advanced_nrf_payload_hint"
                    android:autofillHints="none"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnNrfInject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_nrf_inject"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <Button
                    android:id="@+id/btnNrfJam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_nrf_jam"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:textColor="#F44336"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja BLE Spam -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_ble_title"
                    android:textStyle="bold"
                    android:textColor="#3F51B5"/>

                <Button
                    android:id="@+id/btnBleFlood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_ble_flood"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnLocalBleSpam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOCAL PHONE BLE SPAM"
                    android:layout_marginTop="4dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <Button
                    android:id="@+id/btnBleStop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/advanced_ble_stop"
                    style="@style/Widget.Material3.Button.TextButton"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja Printer Attack -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/printer_attack_title"
                    android:textStyle="bold"
                    android:textColor="#9C27B0"/>
                <Button
                    android:id="@+id/btnOpenPrinterAttack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OPEN PRINTER COMMANDER"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja RF Spoofing (Weather & TPMS) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RF Signal Spoofing"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>

                <Button
                    android:id="@+id/btnOpenWeather"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/weather_title"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <Button
                    android:id="@+id/btnOpenTpms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TPMS SENSOR TOOL"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <Button
                    android:id="@+id/btnOpenSubGhz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SUB-GHZ GATE MASTER"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:textColor="#2196F3"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sekcja RFID / IMMO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            style="@style/Widget.Material3.CardView.Elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RFID &amp; IMMO (PN532/RFID2)"
                    android:textStyle="bold"
                    android:textColor="#E91E63"/>

                <Button
                    android:id="@+id/btnOpenImmo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/immo_scan"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <Button
                    android:id="@+id/btnOpenEmulate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/immo_emulate"
                    style="@style/Widget.Material3.Button.TonalButton"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
